# Plane.so API credentials
# Get your API key from https://app.plane.so/profile/

# Your Plane.so API key
VITE_PLANE_API_KEY=your_plane_api_key_here

# Your workspace slug (e.g. "my-workspace" from app.plane.so/my-workspace/)
VITE_WORKSPACE_SLUG=your_workspace_slug

# The project ID to pull issues from
# Find it in Project Settings → General → Project ID
VITE_PROJECT_ID=your_project_id_here

# (Optional) Override the local dev server URL used by the capture script
# VITE_DEV_SERVER_URL=http://localhost:5173
